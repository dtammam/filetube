#!/usr/bin/env bash
# Pre-commit hook — fast gate before every commit: lint + unit tests.
# Full integration tests run on pre-push instead, to keep commits snappy.
set -euo pipefail

# Source profile for tool paths (nvm, etc.)
[ -f "$HOME/.profile" ] && source "$HOME/.profile" 2>/dev/null || true

echo "Running pre-commit checks..."

if [ ! -d node_modules ]; then
  echo "⚠ node_modules missing — run 'npm install' before committing." >&2
  exit 1
fi

# Lint (fails on errors, not warnings)
echo "→ eslint"
npm run --silent lint

# Fast unit tests only (no server boot)
echo "→ unit tests"
npm run --silent test:unit

echo "Pre-commit checks passed."
