#!/usr/bin/env bash
# Pre-push hook — full gate before pushing: lint + the complete test suite
# (unit + integration).
set -euo pipefail

# Source profile for tool paths (nvm, etc.)
[ -f "$HOME/.profile" ] && source "$HOME/.profile" 2>/dev/null || true

echo "Running pre-push checks..."

if [ ! -d node_modules ]; then
  echo "⚠ node_modules missing — run 'npm install' before pushing." >&2
  exit 1
fi

echo "→ eslint"
npm run --silent lint

echo "→ full test suite"
npm test

echo "Pre-push checks passed."
