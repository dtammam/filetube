# FileTube Configuration

# Docker container image tag to pull/build
FILETUBE_IMAGE_TAG=latest

# The port exposed on the host machine to access the web application
SERVER_HOST_PORT=3000

# Directory on the host where FileTube saves its configurations, database (db.json) and thumbnails (.thumbnails/)
# For local runs, it defaults to the project root. For Docker, it persists configuration.
DATA_DIR=./data

# --- Optional: YouTube subscriptions (yt-dlp) -- off by default ---
# This whole feature is opt-in and additive. Leave it unset/off and FileTube
# behaves exactly as it always has (no new routes, no nav link, no background
# job). See README.md's "Optional: YouTube subscriptions (yt-dlp)" section.

# Master switch. Only "true", "1", or "yes" enable the feature; anything else
# (including unset) keeps it fully disabled.
# FILETUBE_YTDLP_ENABLED=true

# Path (inside the container) to a mounted cookies.txt, used for members-only
# or age-gated videos. Optional -- unset means no cookies are used.
# FILETUBE_YTDLP_COOKIES_FILE=/app/data/cookies.txt

# How often (in minutes) FileTube checks subscriptions for new videos.
# 0 = manual re-pull only (no background poll). Default: 60.
# FILETUBE_YTDLP_POLL_MINUTES=60

# Where downloaded videos are saved. Defaults to a "ytdlp-downloads" folder
# alongside DATA_DIR.
# FILETUBE_YTDLP_DOWNLOAD_DIR=./data/ytdlp-downloads

# Informational only -- reflects the yt-dlp version pinned/bundled in the
# Docker image at build time. Setting this does NOT change or update the
# installed binary; rebuild/pull a newer FileTube image to update yt-dlp.
# FILETUBE_YTDLP_VERSION=2026.7.4
